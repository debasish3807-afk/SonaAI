# Environment variable placeholders (do NOT commit real secrets)

# Firebase (client) - used by the mobile app
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Firebase service account for Cloud Functions (set in Functions environment)
# Provide the service account JSON string or set via Cloud Functions environment configuration
FIREBASE_SERVER_SERVICE_ACCOUNT=

# Gemini API key for server-side usage (Cloud Functions only)
GEMINI_API_KEY=

# Optional Production monitoring
SENTRY_DSN=

# Expo secure store prefix (optional)
EXPO_SECURE_STORE_KEY_PREFIX=sona_
